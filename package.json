{
  "name": "sub-tool",
  "version": "1.0.0",
  "description": "SUB Tool — 線上/桌面上字幕工具 (Arctime 風格)",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "vite build && electron .",
    "electron:dev": "electron . --dev",
    "dist": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.subtool.app",
    "productName": "SUB Tool",
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "win": {
      "target": "portable"
    }
  },
  "devDependencies": {
    "electron": "^32.2.0",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "vite": "^5.4.10",
    "vite-plugin-singlefile": "^2.0.3"
  }
}
