{
  "name": "sub-tool",
  "version": "2.7.0",
  "description": "SUB Tool 上字幕工具",
  "author": "Evan",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "vite build && electron .",
    "electron:dev": "electron . --dev",
    "dist": "vite build && electron-builder"
  },
  "build": {
    "appId": "com.subtool.app",
    "productName": "SUB Tool",
    "icon": "electron/logo.png",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "asarUnpack": [
      "electron/mpv/**",
      "electron/ffmpeg/**"
    ],
    "win": {
      "target": "zip"
    }
  },
  "devDependencies": {
    "electron": "^32.2.0",
    "electron-builder": "^25.1.8",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "vite": "^5.4.10",
    "vite-plugin-singlefile": "^2.0.3"
  }
}