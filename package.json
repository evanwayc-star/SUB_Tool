{
  "name": "sub-tool",
  "version": "3.7.5",
  "description": "SUB Tool 上字幕工具",
  "author": "Evan",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "vite build && electron .",
    "electron:dev": "electron . --dev",
    "dist": "vite build && electron-builder",
    "lint": "eslint src",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.subtool.app",
    "productName": "SUB Tool",
    "icon": "electron/logo.png",
    "fileAssociations": [
      {
        "ext": "subtool",
        "name": "SUB Tool Project",
        "description": "SUB Tool Project File",
        "role": "Editor"
      }
    ],
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "asarUnpack": [
      "electron/mpv/**",
      "electron/ffmpeg/**"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SUB Tool"
    }
  },
  "devDependencies": {
    "electron": "^32.3.3",
    "electron-builder": "^25.1.8",
    "eslint": "^10.5.0",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "vite": "^5.4.10",
    "vite-plugin-singlefile": "^2.0.3",
    "vitest": "^4.1.9"
  }
}
